# Copia este archivo a .env y rellena los valores (no subas .env a git).
# Panel Cloudinary → Dashboard → API Keys

CLOUDINARY_CLOUD_NAME=dtntllea5
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Carpeta raíz en Cloudinary (public_id: authorsite/cronicas-sangre/...)
CLOUDINARY_FOLDER_PREFIX=authorsite

# URL pública del chat API desplegado en Vercel (mismo repo, carpeta api/).
# Ejemplo producción: https://authorsite.vercel.app/api/chat
# En local con npm run dev:chat-api: http://localhost:3001/api/chat
CHAT_API_URL=

# Solo en Vercel (Settings → Environment Variables). No poner en .env del sitio.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
